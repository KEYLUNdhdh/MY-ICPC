\section{搜索架构 (队列调度)}
\begin{frame}{多入口调度：队列 (Queue) 的应用}
    题目要求多入口、多出口，且强制使用队列。
    
    \vspace{0.5cm}
    \textbf{设计模式：广度优先的任务调度器}
    \begin{itemize}
        \item \textbf{初始化}：将生成的多个入口坐标（如 $E_1, E_2, E_3$）压入 \texttt{std::queue} 中。
        \item \textbf{执行流程}：主循环不断执行 \texttt{q.pop()}，取出一个入口点，交由底层的搜索模块进行寻路。
        \item \textbf{优势}：外层队列负责“宏观的多起点调度”，逻辑解耦，极为清晰。
    \end{itemize}
\end{frame}

% --- 第四部分 ---
\section{全路径搜索 (栈与 DFS)}
\begin{frame}{全路径搜索：栈 (Stack) 与深度优先回溯}
    寻找“所有”通路不能使用 BFS，必须采用 DFS 结合状态回溯。
    
    \begin{block}{基于栈的回溯搜索机制}
        在获取到队列分配的起点后，利用 \textbf{系统调用栈 (递归)} 或 \texttt{std::stack} 模拟路径探索：
        \begin{enumerate}
            \item \textbf{前进 (Push)}：走到新节点，将其压栈，并标记为\textbf{已访问}。
            \item \textbf{结算}：若触达任意出口，记录当前栈内路径，但不停止搜索。
            \item \textbf{回退 (Pop) [核心]}：当某节点四个方向皆不可行或已探索完毕，将其出栈，并\textbf{严格撤销其访问标记 (\texttt{visited = false})}。
        \end{enumerate}
    \end{block}
    
    撤销标记是点睛之笔，它允许其他绕行的路线再次经过该点，从而实现“穷举所有通路”。
\end{frame}

